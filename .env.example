# Full URL of the gallery manifest.json, published by the admin app
# when photos are marked "Show on public site" on a submission.
# Example: https://<storage-account>.blob.core.windows.net/submission-images/manifest.json
#
# Optional — if unset, the Our Work section falls back to built-in starter photos.
REACT_APP_GALLERY_MANIFEST_URL=https://submissionimages.blob.core.windows.net/submission-images/manifest.json

